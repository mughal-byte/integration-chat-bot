    <script>
        // Constants for localStorage keys
        const CHAT_STATE_KEY = "chat_state";
        const CHAT_MIN_KEY = "chat_minimized";
        const CHAT_MESSAGES_KEY = "chat_messages";
        const SOUND_ENABLED_KEY = "sound_enabled";

        let moreMenuTimeoutId = null;
        let isAssistantInfoShown = false;
        let sessionUserMessages = 0;

        // Initialize the chat application
        document.addEventListener("DOMContentLoaded", function () {
            loadMessages();
            setupChatInputEvents();
            setupConversationScrollShadow();
            updateSoundUI();

            // Wire up sound toggle checkbox
            const soundToggle = document.getElementById("soundToggle");
            if (soundToggle) {
                soundToggle.addEventListener("change", handleSoundToggle);
            }

            // NEW: Check message count on load
            checkMessageCountAndToggleAssistantInfo();

            // Auto-show first chatbox if 24 hours have passed
            if (shouldShowFirstChatbox()) {
                setTimeout(() => {
                    showFirstChatbox();
                }, 500);
            }
        });




        // Check message count and show/hide assistant info accordingly
        function checkMessageCountAndToggleAssistantInfo() {
            try {
                const raw = localStorage.getItem(CHAT_MESSAGES_KEY) || "[]";
                const messages = JSON.parse(raw);
                const messageCount = messages.length;

                // Agar 5 ya zyada messages hain to show karo
                if (messageCount >= 5) {
                    if (!isAssistantInfoShown) {
                        document.getElementById("assistantInfo").style.display = "block";
                        document.getElementById("ratingButtons").style.display = "flex";
                        isAssistantInfoShown = true;
                    }
                } else {
                    // Agar 5 se kam messages hain to hide karo
                    if (isAssistantInfoShown) {
                        document.getElementById("assistantInfo").style.display = "none";
                        document.getElementById("ratingButtons").style.display = "none";
                        isAssistantInfoShown = false;
                    }
                }
            } catch (error) {
                console.error("Error checking message count:", error);
            }
        }

        // Hide all chat views
        function hideAllChatViews() {
            document.getElementById("chatPage").style.display = "none";
            document.getElementById("fullChat").style.display = "none";
        }

        // Open from floating button
        function openProductExpert() {
            const lastState = getChatState() || "chatPage";
            setMinimized(false);
            if (lastState === "fullChat") {
                openFullChat();
            } else {
                openChatPage();
            }
        }

        // Open chat page
        function openChatPage() {
            hideAllChatViews();
            const chatPage = document.getElementById("chatPage");
            chatPage.style.display = "flex";

            setTimeout(() => {
                chatPage.classList.add("show");
            }, 10);

            saveChatState("chatPage");
        }

        // Minimize chat
        function minimizeChat() {
            const chatPage = document.getElementById("chatPage");
            const fullChat = document.getElementById("fullChat");

            if (chatPage.style.display === "flex") {
                chatPage.classList.remove("show");
                setTimeout(() => {
                    chatPage.style.display = "none";
                }, 300);
            }

            if (fullChat.style.display === "flex") {
                fullChat.classList.remove("show");
                setTimeout(() => {
                    fullChat.style.display = "none";
                }, 300);
            }

            setMinimized(true);
        }

        // Open full chat
        // Open full chat
        function openFullChat() {
            const chatPage = document.getElementById("chatPage");
            if (chatPage) chatPage.classList.remove("show");

            const fullChat = document.getElementById("fullChat");
            fullChat.style.display = "flex";

            setTimeout(() => {
                fullChat.classList.add("show");
            }, 10);

            // Check message count instead of just checking if messages exist
            checkMessageCountAndToggleAssistantInfo();

            const intro = document.querySelector(".chatbox-inline");
            if (intro) {
                intro.style.display = "block";
            }

            const conversationBody = document.getElementById("conversationBody");
            if (conversationBody) {
                conversationBody.scrollTop = 0;
            }

            setTimeout(() => {
                toggleChatboxInline();
            }, 50);

            saveChatState("fullChat");
            setMinimized(false);
        }

        // Close full chat
        function closeFullChat() {
            const fullChat = document.getElementById("fullChat");
            fullChat.classList.remove("show");
            setTimeout(() => {
                hideAllChatViews();
                localStorage.removeItem(CHAT_STATE_KEY);
                setMinimized(true);
            }, 300);
        }

        // Back to chat page
        function backToChatPage() {
            const fullChat = document.getElementById("fullChat");
            fullChat.classList.remove("show");
            setTimeout(() => {
                openChatPage();
            }, 300);
        }

        // Toggle chatbox inline
        function toggleChatboxInline() {
            const intro = document.getElementById("conversationBody")?.querySelector(".chatbox-inline");
            if (intro) intro.style.display = "block";
        }

        // Hide chatbox inline
        function hideChatboxInline() {
            const el = document.getElementById("conversationBody")?.querySelector(".chatbox-inline") || document.querySelector(".chatbox-inline");
            if (el) el.style.display = "none";
        }

        // Render message
        function renderMessage(msg) {
            const body = document.getElementById("conversationBody");
            if (!body) return;

            if (msg.sender === "ai") {
                const row = document.createElement("div");
                row.className = "chat-ai-row";

                const avatar = document.createElement("div");
                avatar.className = "chat-ai-avatar";
                const img = document.createElement("img");
                img.src = "/images/Vector.png";
                img.alt = "AI";
                avatar.appendChild(img);

                const bubble = document.createElement("div");
                bubble.className = "chat-bubble ai";
                bubble.innerHTML = `
                    <div class="ai-bubble-inner">
                        <img src="/images/ai-icon.png" class="ai-icon" alt="AI">
                        <span class="ai-text">${msg.text}</span>
                    </div>
                `;

                row.appendChild(avatar);
                row.appendChild(bubble);
                body.appendChild(row);

                if (isAssistantInfoShown) {
                    document.getElementById("ratingButtons").style.display = "flex";
                }
            } else {
                const bubble = document.createElement("div");
                bubble.className = "chat-bubble user";
                bubble.textContent = msg.text;
                body.appendChild(bubble);
            }
            body.scrollTop = body.scrollHeight;
        }

        // Load messages
        function loadMessages() {
            try {
                const raw = localStorage.getItem("chat_messages") || "[]";
                let messages = JSON.parse(raw);

                // Safety checks
                if (!messages || !Array.isArray(messages)) {
                    messages = [];
                    localStorage.setItem("chat_messages", JSON.stringify(messages));
                    return;
                }

                // Filter messages safely
                const filteredMessages = messages.filter(msg => {
                    if (!msg || !msg.text) return false;
                    return true;
                });

                // Render messages
                filteredMessages.forEach(msg => {
                    if (msg && msg.text) {
                        renderMessage(msg);
                    }
                });
            } catch (error) {
                console.error("Error loading messages:", error);
                localStorage.setItem("chat_messages", "[]");
            }
        }

        // Send message
        function sendMessage() {
            const input = document.getElementById("chatInput");
            if (!input) return;

            const message = input.value.trim();

            // Validate message
            if (!message) {
                // Show visual feedback for empty message
                input.style.borderColor = "#ef4444";
                setTimeout(() => {
                    input.style.borderColor = "";
                }, 500);
                return;
            }

            // Prevent sending if message is too long
            if (message.length > 5000) {
                alert("Message is too long. Please keep it under 5000 characters.");
                return;
            }

            // Prevent sending while AI is responding
            const sendButton = document.querySelector(".conversation-send");
            if (sendButton && sendButton.disabled) {
                return;
            }

            // Disable send button while processing
            if (sendButton) {
                sendButton.disabled = true;
                sendButton.style.opacity = "0.5";
                sendButton.style.cursor = "not-allowed";
            }

            const intros = document.querySelectorAll(".chatbox-inline, .welcome-pills");
            intros.forEach(intro => {
                intro.style.display = "none";
            });



            const conversationBody = document.getElementById("conversationBody");

            const userBubble = document.createElement("div");
            userBubble.classList.add("chat-bubble", "user");
            userBubble.textContent = message;
            conversationBody.appendChild(userBubble);
            conversationBody.scrollTop = conversationBody.scrollHeight;

            // Clear input and reset height
            input.value = "";
            input.style.height = "auto";
            input.style.height = "30px";

            // Focus back on input
            input.focus();

            // Clear file previews if any
            const inputPreview = document.getElementById("inputPreview");
            if (inputPreview) {
                inputPreview.innerHTML = "";
                updateTextareaLayout();
            }

            saveMessage({ sender: "user", text: message });
            sessionUserMessages++;

            simulateAiResponse(message);
        }

        // Simulate AI response - UPDATED VERSION
        async function simulateAiResponse(userMessage) {
            const conversationBody = document.getElementById("conversationBody");
            const sendButton = document.querySelector(".conversation-send");

            const typingDiv = document.createElement("div");
            typingDiv.classList.add("typing");
            typingDiv.innerHTML = `<span></span><span></span><span></span>`;
            conversationBody.appendChild(typingDiv);
            conversationBody.scrollTop = conversationBody.scrollHeight;

            try {
                // Get or create session key
                let sessionKey = localStorage.getItem("chat_session_key");
                if (!sessionKey) {
                    sessionKey = 'user_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
                    localStorage.setItem("chat_session_key", sessionKey);
                }

                // Send request to YOUR server
                const res = await fetch("/chat", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({
                        message: userMessage,
                        session_key: sessionKey
                    }),
                });

                const data = await res.json();
                typingDiv.remove();

                console.log("📥 Server Response:", data);

                if (!res.ok) {
                    throw new Error(data.reply || data.error || `Server Error: ${res.status}`);
                }

                // Get reply from response
                let aiReply = data.reply || data.response || data.message;

                if (!aiReply || aiReply.trim().length === 0) {
                    aiReply = "I received your message but couldn't generate a proper response.";
                }

                const cleanReply = aiReply.trim();
                const aiBubble = createAiBubble(cleanReply);
                conversationBody.appendChild(aiBubble);
                conversationBody.scrollTop = conversationBody.scrollHeight;

                saveMessage({ sender: "ai", text: cleanReply });
                playNotificationSound();

                // Update session key if returned
                if (data.session_key) {
                    localStorage.setItem("chat_session_key", data.session_key);
                }

                saveMessage({ sender: "ai", text: cleanReply });
                playNotificationSound();

                // NEW: Auto-check message count after AI response
                checkMessageCountAndToggleAssistantInfo();

            } catch (err) {
                typingDiv.remove();
                console.error("❌ Error getting AI response:", err);

                // User-friendly error message
                let errorMessage = "Sorry, I'm having trouble responding. ";

                if (err.message.includes("Failed to fetch")) {
                    errorMessage = "Cannot connect to server. Please check if the server is running on port 5000.";
                } else if (err.message.includes("network")) {
                    errorMessage = "Network error. Please check your internet connection.";
                } else {
                    errorMessage += "Error: " + err.message;
                }

                const aiBubble = createAiBubble(errorMessage);
                conversationBody.appendChild(aiBubble);
                conversationBody.scrollTop = conversationBody.scrollHeight;

                saveMessage({ sender: "ai", text: errorMessage });
                playNotificationSound();

            } finally {
                // Re-enable send button
                if (sendButton) {
                    sendButton.disabled = false;
                    sendButton.style.opacity = "1";
                    sendButton.style.cursor = "pointer";
                }
            }
        }

        // Create AI bubble
        function createAiBubble(text) {
            const aiBubble = document.createElement("div");
            aiBubble.classList.add("chat-bubble", "ai");

            const innerDiv = document.createElement("div");
            innerDiv.className = "ai-bubble-inner";

            // Remove the image completely
            // const img = document.createElement("img");
            // img.src = "/images/Vector.png";
            // img.className = "ai-icon";
            // img.alt = "AI";
            // img.onerror = function () { this.style.display = "none"; };
            // innerDiv.appendChild(img);

            const textSpan = document.createElement("span");
            textSpan.className = "ai-text";
            textSpan.textContent = text; // Use textContent for safety

            innerDiv.appendChild(textSpan);
            aiBubble.appendChild(innerDiv);

            return aiBubble;
        }


        // Setup chat input events
        function setupChatInputEvents() {
            const input = document.getElementById("chatInput");
